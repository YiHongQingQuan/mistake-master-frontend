{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/public/index.html"
    }
  ],
  "builds": [
    {
      "src": "public/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/public/渣枙淕燴湮呇V2.0.html"
    },
    {
      "src": "/login",
      "dest": "/public/login.html"
    },
    {
      "handle": "filesystem"
    }
  ]
}